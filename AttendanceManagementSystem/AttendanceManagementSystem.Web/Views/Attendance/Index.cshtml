@{
    ViewData["Title"] = "Attendance";
}

<div class="container mt-4">
    <h3 class="mb-3">Attendance Management</h3>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" asp-action="GetReport" class="mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-md-6 col-lg-4">
                <input type="text" class="form-control" name="userId" placeholder="Enter User ID" required />
            </div>
            <div class="col-md-6 col-lg-8 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary flex-fill" formaction="/Attendance/CheckIn">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Check In
                </button>
                <button type="submit" class="btn btn-warning flex-fill" formaction="/Attendance/CheckOut">
                    <i class="bi bi-box-arrow-right me-1"></i> Check Out
                </button>
                <button type="submit" class="btn btn-success flex-fill" formaction="/Attendance/Report">
                    <i class="bi bi-file-earmark-text me-1"></i> Get Report
                </button>
            </div>
        </div>
    </form>
</div>
