@model AssismentStudent.MVC.Response.PaginationResponse<AssismentStudent.MVC.Models.StudentViewModel>


@{
    ViewData["Title"] = "Student Data";
}

<h1>@ViewData["Title"]</h1>
<div>
    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create New
        </a>
    </div>

    <div class="mb-3 d-flex justify-content-end">
        <a asp-action="DownloadReport" method="Get" class="btn btn-secondary" >
            Generate PDF
        </a>
    </div>
</div>


<form asp-action="Search" method="get" class="d-flex mb-3">
    <input type="text" name="name" class="form-control me-2" placeholder="Search by Name" value="@ViewBag.SearchName" />
    <input type="text" name="address" class="form-control me-2" placeholder="Search by Address" value="@ViewBag.SearchAddress"  />
    <button type="submit" class="btn btn-success">Search</button>
</form>


