@model List<AssetManagement.Domain.Dtos.CategoryDto>

<h2>Categories</h2>
<a href="/Category/Create">Create New Category</a>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.CategoryName</td>
            </tr>
        }
    </tbody>
</table>