@model AssetManagement.Domain.Dtos.AssetDto.UpdateAssetDto

@{
    ViewData["Title"] = "Update Asset";
}

<h2>Update Asset</h2>
@if (ViewBag.Error != null)
{
    <div class="alert alert-warning">@ViewBag.Error</div>
}

<form asp-action="Update" method="post">

    <div class="mb-3">
        <label asp-for="Id" class="form-label">Id</label>
        <input asp-for="Id" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="UserName" class="form-label">UserName</label>
        <input asp-for="UserName" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="DepartmentName" class="form-label">DepartmentName</label>
        <input asp-for="DepartmentName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Cost" class="form-label">Cost</label>
        <input asp-for="Cost" class="form-control" type="number" step="0.01" />
    </div>

    <div class="mb-3 form-check">
        <input asp-for="Status" class="form-check-input" type="checkbox" />
        <label asp-for="Status" class="form-check-label">Active</label>
    </div>


    <button type="submit" class="btn btn-primary">Update</button>
</form>