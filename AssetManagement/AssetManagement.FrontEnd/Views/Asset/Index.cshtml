@using AssetManagement.Domain.Dtos
@using AssetManagement.Domain.Dtos.AssetDto
@* @using AssetManagement.Domain.Dtos.AssetDto.GetAssetDto *@
@* @model List<GetAssetDto> *@
@model PageResponse<GetAssetDto>

<h2 class="mb-4">Assets</h2>
<a href="/Asset/Create" class="btn btn-primary mb-3">Create New Asset</a>

<div class="row">
    @foreach (var asset in Model.Items)
    {
        <div class="col-md-4 col-sm-5 col-lg-3 mb-4">
            <div class="card h-100">
                <div class="card-body">
                            <h5 class="card-title">@asset.Name</h5>
                    
                    <p class="card-text">SN Number: @asset.SerialNumber</p>
                    <p class="card-text">Category Name: @asset.CategoryName</p>
                    <p class="card-text">
                        Status: @if (asset.Status  == true)
                        {
                        <button class=" btn btn-success"></button>
                        }
                        else
                        {
                        <button class="btn btn-danger"></button>
                        }
                    </p>
                    <p class="card-text">Cost: NPR @asset.Cost</p>
                </div>
            </div>
        </div>
    }
</div>
