@model AssetManagementSystem.Shared.Dtos.Tag.TagReadDto

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Asset</h3>
        </div>
        <div class="card-body">
            <h5>Are you sure you want to delete this asset?</h5>
            <hr />
            <dl class="row">
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.Id)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.Id)
                </dd>

                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.MacAddress)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.MacAddress)
                </dd>

                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.AssetId)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.AssetId)
                </dd>

                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.AssetName)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.AssetName)
                </dd>

        
                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.Description)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.Description)
                </dd>

                <dt class = "col-sm-2">
                    @Html.DisplayNameFor(model => model.CreatedAt)
                </dt>
                <dd class = "col-sm-10">
                    @Html.DisplayFor(model => model.CreatedAt)
                </dd>

       
            </dl>
    
            </div>
            <div class="card-footer text-end">
    
                <form asp-action="Delete">
                    <input type="submit" value="Delete" class="btn btn-danger" /> |
                    <a asp-action="Index">Back to List</a>
                </form>
        </div>
    </div>
</div>
