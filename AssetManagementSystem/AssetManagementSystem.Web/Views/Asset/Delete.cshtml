@model AssetManagementSystem.Shared.Dtos.Asset.AssetReadDto

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Asset</h3>
        </div>
        <div class="card-body">
            <h5>Are you sure you want to delete this asset?</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Asset Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.AssetName)</dd>

                <dt class="col-sm-3">Serial Number</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.SerialNumber)</dd>

                <dt class="col-sm-3">Category</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.AssetCategory)</dd>

                <dt class="col-sm-3">Received Date</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ReceivedDate)</dd>

                <dt class="col-sm-3">Department ID</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.DepartmentId)</dd>

                <dt class="col-sm-3">Department Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.DepartmentName)</dd>

                <dt class="col-sm-3">Tag ID</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.TagId)</dd>

                <dt class="col-sm-3">Tag Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.TagName)</dd>

                <dt class="col-sm-3">Asset ID</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <form asp-action="Delete" class="d-inline">
                <button type="submit" class="btn btn-danger me-2">Delete</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>
