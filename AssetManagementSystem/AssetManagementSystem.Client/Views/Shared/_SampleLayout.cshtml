<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Asset Management Dashboard</title>

   
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/AssetManagementSystem.Client.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

   
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" xintegrity="sha512-SnH5WK+bZxgPHs44uWIX+LLMDJ8uRjWzHjYm/zKk2sI2z7g3N7R1bN0xW4Wl2uM3Q/2l4F6+wA0X1+l5kX0A==" crossorigin="anonymous" referrerpolicy="no-referrer" />

  
</head>
 <body class="bg-light">

    <div class="collapse d-md-block bg-secondary  border-end h-100 position-fixed" >
        <div class="d-flex h-100 flex-column ">
            
            <div class="py-3 px-3 border-bottom">
                <a asp-controller="Home" asp-action="Index" class="navbar-brand fw-semibold text-light ">
                    <i class="bi bi-laptop me-2"></i>AssetMgmt
                </a>
            </div>

           
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-light d-flex align-items-center py-2 px-3 " >
                        <i class="bi bi-house me-2"></i> Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-light d-flex align-items-center py-2 px-3" href="#">
                        <i class="bi bi-shield-lock me-2"></i> Privacy
                    </a>
                </li>
            </ul>

           
            
        </div>
    </div>



    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
