@using AssetManagementSystem.Client.Models.Tag
@model PagedViewModel<TagViewModel>

<h3 class="mb-4 text-primary fw-bold">All Tags</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-x-octagon-fill me-2"></i><strong>Error:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-x-octagon-fill me-2"></i><strong>Error:</strong> @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (ViewBag.Success != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i><strong>Success!</strong> @ViewBag.Success
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i><strong>Success!</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    var currentSort = TempData["CurrentSort"] as string;
}

<div class="card shadow-sm mb-2">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

           
            <div class="d-flex align-items-center gap-2">
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-circle me-1"></i> Create New
                </a>
            </div>

            <div class="d-flex align-items-center gap-2">
                <form method="get" asp-action="Index" class="m-0">
                    <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]" />
                    <input type="hidden" name="sortOrder" value="@TempData["CurrentSort"]" />
                    <select name="status" class="form-select form-select-sm"
                            style="width: 120px;"
                            onchange="this.form.submit();">
                        <option value="">Status</option>
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </form>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-circle me-1"></i> Clear
            </a>


            
            <div class="d-flex align-items-center gap-2 flex-grow-1 justify-content-end">
                <form method="get" class="d-flex" role="search" asp-action="Index">
                    <div class="input-group" style="max-width: 300px;">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="search" class="form-control border-start-0"
                               name="searchString"
                               value="@ViewData["CurrentFilter"]"
                               placeholder="Search tags..." aria-label="Search">
                    </div>
                </form>

                <a asp-action="ExportToExcel" class="btn btn-success btn-sm">
                    <i class="bi bi-file-earmark-excel me-1"></i> Export
                </a>
            </div>

        </div>
    </div>
</div>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle border shadow-sm">
            <thead class="table-secondary">
                <tr class="text-center align-middle">
                    <th class="text-start">
                        <a class="text-dark d-flex align-items-center"
                           asp-action="Index"
                           asp-route-pageNumber="@Model.PageIndex"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-sortOrder="@TempData["NameSortParam"]"
                           asp-route-currentFilter="@ViewData["CurrentFilter"]">
                            Mac Address
                            @if (currentSort == "name_desc")
                            {
                                <i class="bi bi-caret-down-fill ms-1"></i>
                            }
                            else if (currentSort == "name_asc")
                            {
                                <i class="bi bi-caret-up-fill ms-1"></i>
                            }
                        </a>
                    </th>

                    <th class="text-center">Active</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var tag in Model.Items)
                {
                    <tr class="align-middle">
                        <td style="display:none">@tag.Id</td>
                        <td class="fw-semibold text-start">@tag.MacAddress</td>

                        
                        <td class="text-center">
                            <form asp-action="ToggleActive" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@tag.Id" />
                                <input type="hidden" name="newStatus" value="@(tag.IsActive ? "InActive" : "Active")" />
                                <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]" />
                                <input type="hidden" name="pageNumber" value="@Model.PageIndex" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="sortOrder" value="@TempData["CurrentSort"]" />

                                <div class="d-flex justify-content-center align-items-center">
                                    <div class="form-check form-switch m-0">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               @(tag.IsActive ? "checked" : "")
                                               onchange="this.form.submit();" />
                                    </div>
                                </div>
                            </form>
                        </td>

                        <td class="text-center text-nowrap">
                            <a asp-action="Update" class="btn btn-sm btn-primary" asp-route-id="@tag.Id">
                                Edit
                            </a>
                            <a asp-action="Delete" class="btn btn-sm btn-danger ms-1" asp-route-id="@tag.Id">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>


    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top flex-wrap gap-2">
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle btn-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                Page Size: <span class="fw-bold">@Model.PageSize</span>
            </button>
            <ul class="dropdown-menu">
                @{
                    var sizes = new int[] { 5, 10, 15, 20 };
                }
                @foreach (var size in sizes)
                {
                    <li>
                        <a class="dropdown-item @(Model.PageSize == size ? "active" : "")"
                           asp-action="Index"
                           asp-route-pageNumber="1"
                           asp-route-pageSize="@size"
                           asp-route-sortOrder="@TempData["CurrentSort"]"
                           asp-route-searchString="@ViewData["CurrentFilter"]">
                            @size
                        </a>
                    </li>
                }
            </ul>
        </div>

        <div class="text-muted">
            @{
                int startItem = (Model.PageIndex - 1) * Model.PageSize + 1;
                int endItem = Math.Min(Model.PageIndex * Model.PageSize, Model.TotalItems);
            }
            Showing @startItem to @endItem of @Model.TotalItems items
        </div>

        <nav>
            <ul class="pagination pagination-sm mb-0">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pageNumber="@i"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-sortOrder="@TempData["CurrentSort"]"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
else
{
    <div class="alert alert-info text-center mt-4 shadow-sm" role="alert">
        <i class="bi bi-info-circle fs-4 me-2"></i>
        <p class="mb-0 mt-2">No tags found</p>
    </div>
}
