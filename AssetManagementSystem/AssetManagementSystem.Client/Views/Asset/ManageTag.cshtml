@using AssetManagementSystem.Client.Models.Assets
@model AssetViewModel

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between">
            <h5 class="mb-0">
                <i class="bi bi-tags me-2"></i>
                Manage Tags
            </h5>
        </div>

        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-x-octagon-fill me-2"></i><strong>Error:</strong> @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-x-octagon me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Asset Name</label>
                    <input asp-for="Name" class="form-control" readonly />
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">Serial Number</label>
                    <input asp-for="SerialNumber" class="form-control" readonly />
                </div>
            </div>

            <hr />

            <!-- Assigned Tags Table -->
            <div class="mt-3">
                <label class="form-label fw-semibold">Assigned Tags</label>
                @if (Model.TagMacAddress != null && Model.TagMacAddress.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th>Tag Mac Address</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.TagMacAddress.Count; i++)
                                {
                                    <tr>
                                        <td class="text-center">@(@i + 1)</td>
                                        <td>@Model.TagMacAddress[i]</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted fst-italic">No tags assigned yet.</div>
                }
            </div>

            <hr />

            <!-- Tag Assignment and Buttons -->
            <form asp-action="AssignTag" method="post" id="assignTagForm">
                <input type="hidden" value="@Model.Id" name="Id" />

                <div class="col-md-6 mt-3">
                    <label class="form-label fw-semibold">Select Tag</label>
                    <select name="selectedTagId" class="form-select" asp-items="ViewBag.Tags">
                        <option value="">-- Select Tag MacAddress --</option>
                    </select>
                </div>
            </form>

            <form asp-action="RemoveTag" method="post" id="removeTagForm">
                <input type="hidden" name="id" value="@Model.Id" />
            </form>

            <!-- Unified Button Row -->
            <div class="d-flex justify-content-between align-items-center mt-4">
                <!-- Left: Back Button -->
                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>

                <!-- Right: Assign + Remove Buttons -->
                <div class="d-flex gap-2">
                    <button type="submit" form="assignTagForm" class="btn btn-primary px-4">
                        <i class="bi bi-plus-circle me-1"></i> Assign Tag
                    </button>

                    <button type="submit"
                        form="removeTagForm"
                            class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to remove ALL tags from this asset?');">
                        <i class="bi bi-trash me-1"></i> Remove All
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
