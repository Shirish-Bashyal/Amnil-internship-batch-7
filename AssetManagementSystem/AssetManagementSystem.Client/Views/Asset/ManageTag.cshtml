@using AssetManagementSystem.Client.Models.Assets
@model AssetViewModel

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between">
            <h5 class="mb-0">
                <i class="bi bi-tags me-2"></i>
                @(string.IsNullOrEmpty(Model.TagMacAddress) ? "Assign Tag" : "Remove Tag")
            </h5>
        </div>

        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-x-octagon-fill me-2"></i><strong>Error:</strong> @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-x-octagon me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="row g-3">
               
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Asset Name</label>
                    <input asp-for="Name" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Serial Number</label>
                    <input asp-for="SerialNumber" class="form-control" readonly />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Tag Mac Address</label>
                    <input asp-for="TagMacAddress" class="form-control" readonly />
                </div>
            </div>

            <hr />

           
            @if (string.IsNullOrEmpty(Model.TagMacAddress))
            {
                
                <form asp-action="AssignTag" method="post">
                    <input type="hidden" value="@Model.Id"  name="Id" />

                    <div class="col-md-6 mt-3">
                        <label class="form-label fw-semibold">Select Tag</label>
                        <select name="selectedTagId" class="form-select" asp-items="ViewBag.Tags">
                            <option value="">-- Select Tags MacAddress --</option>
                        </select>
                    </div>
                   

                  
                       
                        <div class="col-12 mt-3 d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary px-4">
                                <i class="bi bi-arrow-left me-1"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-plus-circle me-1"></i> Assign Tag

                            </button>

                    </div>
                </form>
            }
            else
            {

                <form asp-action="RemoveTag" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="alert alert-info mt-4">
                        <i class="bi bi-info-circle me-2"></i>
                        This asset already has an assigned tag. You can remove it below.
                    </div>

                    <div class="col-12 mt-3 d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary px-4">
                            <i class="bi bi-arrow-left me-1"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i> Remove Tag
                        </button>
                      
                    </div>
                </form>

            }
        </div>
    </div>
</div>
