@using AssetManagementSystem.Client.Models.Dashboard
@model DashboardViewModel

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-x-octagon-fill me-2"></i><strong>Error:</strong> @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-4">
    <h4 class="mb-4 fw-bold text-primary"><i class="bi bi-speedometer2 me-2"></i> Dashboard</h4>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm text-center border-0">
                <div class="card-body">
                    <h6>Total Assets</h6>
                    <h3 class="text-primary fw-bold">@Model.Assets</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center border-0">
                <div class="card-body">
                    <h6>Active Assets</h6>
                    <h3 class="text-success fw-bold">@Model.ActiveAssets</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center border-0">
                <div class="card-body">
                    <h6>Total Tags</h6>
                    <h3 class="text-info fw-bold">@Model.Tags</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center border-0">
                <div class="card-body">
                    <h6>Active Tags</h6>
                    <h3 class="text-success fw-bold">@Model.ActiveTags</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center border-0">
                <div class="card-body">
                    <h6>Categories</h6>
                    <h3 class="text-warning fw-bold">@Model.Categories</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center border-0">
                <div class="card-body">
                    <h6>Departments</h6>
                    <h3 class="text-secondary fw-bold">@Model.Departments</h3>
                </div>
            </div>
        </div>
    </div>
</div>
